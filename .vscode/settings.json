{
    "files.encoding": "utf8",
    "files.eol": "\r\n",
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "files.exclude": {
        "**/.lake": true
    },
    "search.exclude": {
        "**/.lake": true
    },
    "chat.tools.terminal.enableAutoApprove": true,
    "chat.tools.terminal.autoApprove": {
        // lean-setup
        "pwsh.exe -File .github/skills/lean-setup/scripts/setup.ps1": true,
        "bash .github/skills/lean-setup/scripts/setup.sh": true,
        // lean-build
        "pwsh.exe -File .github/skills/lean-build/scripts/build.ps1": true,
        "pwsh.exe -File .github/skills/lean-build/scripts/build.ps1 -Clean": true,
        "pwsh.exe -File .github/skills/lean-build/scripts/build.ps1 -Update": true,
        "bash .github/skills/lean-build/scripts/build.sh": true,
        "bash .github/skills/lean-build/scripts/build.sh --clean": true,
        "bash .github/skills/lean-build/scripts/build.sh --update": true,
        // lean-run
        "pwsh.exe -File .github/skills/lean-run/scripts/run.ps1": true,
        "bash .github/skills/lean-run/scripts/run.sh": true
    }
}
